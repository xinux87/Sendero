# Secretos y configuración local
.env

# Datos de usuario (BD, GPX subidos, fotos)
data/

# GPX de ejemplo con datos reales
examples/

# Carpeta de importación automática (puede contener archivos personales)
watch/

# Defensa en profundidad: datos personales por extensión, aunque estén fuera de data/
# (BD, tracks y fotos nunca deben commitearse)
*.db
*.sqlite
*.sqlite3
*.gpx
*.fit
*.jpg
*.jpeg
*.png
# Excepción: los assets estáticos de la app y las capturas del README sí se versionan
!static/**
!readme_images/**

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Claude Code
.claude/

# Sistema / editores
.DS_Store
Thumbs.db
*.swp
*.swo
