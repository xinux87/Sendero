# Plantilla de configuración. Copia a .env y ajusta:  cp .env.example .env
# .env está en .gitignore. Docker Compose lee .env automáticamente al hacer
# `docker compose ... up` desde este directorio.

# ── Despliegue (Docker Compose sustituye estas variables) ──
# Versión de la imagen a desplegar (tag en Docker Hub: xinux87/sendero:<versión>).
SENDERO_VERSION=0.5.0
# Ruta en el HOST de los datos (BD, GPX, fotos, thumbs). Se monta en /data.
SENDERO_DATA_DIR=./data
# Ruta en el HOST de la carpeta vigilada por el watcher (GPX que deja Syncthing).
SENDERO_WATCH_DIR=./watch

# Integración con Immich (opcional)
# Si no se configura, el botón "Buscar en Immich" permanece oculto.
IMMICH_URL=http://tu-servidor:2283
IMMICH_API_KEY=tu_api_key_aqui
IMMICH_MARGIN_MIN=180

# Cookie de sesión de Wikiloc (opcional, para importar rutas desde Wikiloc)
# Wikiloc bloquea peticiones automatizadas sin sesión válida.
# Cómo obtenerla: abre Wikiloc en el navegador con tu cuenta,
# DevTools (F12) → Network → cualquier petición a wikiloc.com → cabecera "Cookie".
# Copia el valor completo y pégalo aquí.
WIKILOC_COOKIE=
